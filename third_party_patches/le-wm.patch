+defaults:
+  - launcher: local
+  - solver: cem
+  - _self_
+
+# Mirrors reacher.yaml but points at the local latent-brs checkpoint and
+# reacher_expert dataset instead of the upstream dmc/reacher_random dataset.
+# Run with:
+#   cd third_party/le-wm && STABLEWM_HOME=<repo>/lewm_home MUJOCO_GL=egl \
+#     python3 eval.py --config-name=reacher_latentbrs
+# The checkpoint is expected at $STABLEWM_HOME/checkpoints/reacher/lewm_vel_object.ckpt
+# (produced by convert_velocity_ckpt.py) and the dataset at
+# $STABLEWM_HOME/reacher_expert.h5 (symlink to data/expert_data/reacher_expert.h5).
+
+world:
+  env_name: swm/ReacherDMControl-v0
+  num_envs: ${eval.num_eval}
+  max_episode_steps: ???
+  # history_size matches train/lewm_train_mlp.py (default 3 frames of context).
+  history_size: 3
+  frame_skip: 1
+  task: qpos_match
+  # Render at the dataset's native resolution so the replay init frames and
+  # the env-rendered frames have a matching shape (eval.py forwards this into
+  # world = swm.World(..., image_shape=(image_size, image_size))).
+  image_size: 252
+
+dataset:
+  stats: ${eval.dataset_name}
+  keys_to_cache:
+    - action
+  # reacher_expert.h5 mixes per-row columns with per-episode columns
+  # (episode_seed, reward, terminated). Restrict to per-row columns so
+  # get_row_data / load_chunk stay consistent.
+  keys_to_load:
+    - action
+    - pixels
+    - qpos
+    - qvel
+    - observation
+    - episode_idx
+    - step_idx
+
+seed: 42
+policy: reacher/lewm_vel
+
+plan_config:
+  horizon: 5
+  receding_horizon: 5
+  # Our model trains on single-step 2-dim actions (frameskip=1, no blocking),
+  # so each planning step corresponds to one environment step.
+  action_block: 1
+
+eval:
+  num_eval: 50
+  goal_offset_steps: 25
+  eval_budget: 50
+  img_size: 224
+  dataset_name: reacher_expert
+  callables:
+    - method: set_state
+      args:
+        qpos:
+          value: qpos
+        qvel:
+          value: qvel
+
+    - method: set_target_qpos
+      args:
+        target_qpos:
+          value: goal_qpos
+
+output:
+  system: reacher
+  dir: ${oc.env:STABLEWM_HOME}/eval_outputs
+  filename: latentbrs_results.txt
