@@ -0,0 +1,328 @@
+#!/usr/bin/env python3
+"""Convert LeWM/stable-worldmodel weights into an object checkpoint.
+
+The LeWM evaluation script loads policies through
+``stable_worldmodel.policy.AutoCostModel``. In this checkout that loader expects
+an object checkpoint named ``*_object.ckpt`` under
+``$STABLEWM_HOME/checkpoints``. The Hugging Face repo
+``quentinll/lewm-pusht`` provides the newer ``config.json`` + ``weights.pt``
+format instead.
+
+This script rebuilds the model from either a Hydra-instantiable HF config or a
+stable-worldmodel training config, loads ``weights.pt``/``weights_epoch_*.pt``,
+and saves a loadable object checkpoint, usually:
+
+    $STABLEWM_HOME/checkpoints/pusht/lewm_object.ckpt
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import sys
+from collections import OrderedDict
+from pathlib import Path
+
+import torch
+from hydra.utils import instantiate
+from omegaconf import DictConfig, OmegaConf
+
+
+LEWM_DIR = Path(__file__).resolve().parent
+REPO_ROOT = LEWM_DIR.parent.parent
+
+# Prefer the checked-out third_party packages when this script is run from the
+# project repo, but still work if the packages are only installed in the venv.
+for rel in ("third_party/stable-worldmodel", "third_party/stable-pretraining"):
+    path = REPO_ROOT / rel
+    if path.exists() and str(path) not in sys.path:
+        sys.path.insert(0, str(path))
+
+
+def default_src_dir() -> Path:
+    return REPO_ROOT / "pusht" / "models" / "lewm-pusht"
+
+
+def default_dst_path() -> Path:
+    try:
+        import stable_worldmodel as swm
+
+        root = swm.data.utils.get_cache_dir(sub_folder="checkpoints")
+    except Exception:
+        root = Path(os.getenv("STABLEWM_HOME", Path.home() / ".stable_worldmodel"))
+        root = root / "checkpoints"
+    return root / "pusht" / "lewm_object.ckpt"
+
+
+def load_state_dict(path: Path) -> dict[str, torch.Tensor]:
+    state = torch.load(path, map_location="cpu")
+    if isinstance(state, dict) and "state_dict" in state:
+        state = state["state_dict"]
+    if isinstance(state, dict) and "model" in state and isinstance(state["model"], dict):
+        state = state["model"]
+    if not isinstance(state, dict):
+        raise TypeError(f"Expected a state_dict-like object in {path}, got {type(state)!r}")
+    return state
+
+
+def _cfg_get(config: dict, dotted_key: str, default=None):
+    current = config
+    for part in dotted_key.split("."):
+        if not isinstance(current, dict) or part not in current:
+            return default
+        current = current[part]
+    return current
+
+
+def _infer_train_config_kind(config: dict, weights_path: Path) -> str | None:
+    text = " ".join(
+        str(value).lower()
+        for value in (
+            weights_path.parent.name,
+            weights_path.parent.parent.name,
+            config.get("output_model_name", ""),
+            _cfg_get(config, "wm.type", ""),
+        )
+    )
+    if "pldm" in text:
+        return "pldm"
+    if "lewm" in text:
+        return "lewm"
+    if "dinowm" in text or "prejepa" in text:
+        return "dinowm"
+    return None
+
+
+def _build_pldm_or_lewm_from_train_config(config: dict, kind: str) -> torch.nn.Module:
+    import stable_pretraining as spt
+
+    if kind == "pldm":
+        from stable_worldmodel.wm.pldm import PLDM
+        from stable_worldmodel.wm.pldm.module import Embedder, MLP, Predictor
+    elif kind == "lewm":
+        from stable_worldmodel.wm.lewm import LeWM as PLDM
+        from stable_worldmodel.wm.lewm.module import Embedder, MLP, Predictor
+    else:
+        raise ValueError(f"Unsupported training config kind: {kind}")
+
+    wm_cfg = config["wm"]
+    data_cfg = config.get("data", {}).get("dataset", {})
+    img_size = int(config.get("img_size", 224))
+    patch_size = int(config.get("patch_size", 14))
+    encoder_scale = str(config.get("encoder_scale", "tiny"))
+
+    encoder = spt.backbone.utils.vit_hf(
+        encoder_scale,
+        patch_size=patch_size,
+        image_size=img_size,
+        pretrained=False,
+        use_mask_token=False,
+    )
+    hidden_dim = int(encoder.config.hidden_size)
+    embed_dim = int(wm_cfg.get("embed_dim", hidden_dim))
+    frameskip = int(data_cfg.get("frameskip", 1))
+    action_dim = int(wm_cfg.get("action_dim", 2))
+    effective_action_dim = frameskip * action_dim
+
+    predictor = Predictor(
+        num_frames=int(wm_cfg["history_size"]),
+        input_dim=embed_dim,
+        hidden_dim=hidden_dim,
+        output_dim=hidden_dim,
+        **dict(config["predictor"]),
+    )
+    action_encoder = Embedder(input_dim=effective_action_dim, emb_dim=embed_dim)
+    projector = MLP(
+        input_dim=hidden_dim,
+        output_dim=embed_dim,
+        hidden_dim=2048,
+        norm_fn=torch.nn.BatchNorm1d,
+    )
+    predictor_proj = MLP(
+        input_dim=hidden_dim,
+        output_dim=embed_dim,
+        hidden_dim=2048,
+        norm_fn=torch.nn.BatchNorm1d,
+    )
+    return PLDM(
+        encoder=encoder,
+        predictor=predictor,
+        action_encoder=action_encoder,
+        projector=projector,
+        pred_proj=predictor_proj,
+    )
+
+
+def _build_dinowm_from_train_config(config: dict) -> torch.nn.Module:
+    import stable_pretraining as spt
+    import stable_worldmodel as swm
+    from omegaconf import OmegaConf
+    from stable_worldmodel.wm.prejepa.module import CausalPredictor, Embedder
+    from transformers import AutoModel, AutoModelForImageClassification
+    from torch import nn
+
+    encoder_configs = {
+        "resnet": {
+            "prefix": "microsoft/resnet-",
+            "model_class": AutoModelForImageClassification,
+            "embedding_attr": lambda m: m.config.hidden_sizes[-1],
+            "post_init": lambda m: setattr(m.classifier, "1", nn.LayerNorm(m.config.hidden_sizes[-1])),
+            "interpolate_pos_encoding": False,
+        },
+        "vit": {"prefix": "google/vit-"},
+        "dino": {"prefix": "facebook/dino-"},
+        "dinov2": {"prefix": "facebook/dinov2-"},
+        "dinov3": {"prefix": "facebook/dinov3-"},
+        "webssl": {"prefix": "facebook/webssl-"},
+        "mae": {"prefix": "facebook/vit-mae-"},
+        "ijepa": {"prefix": "facebook/ijepa"},
+        "vjepa2": {"prefix": "facebook/vjepa2-vit"},
+        "siglip2": {"prefix": "google/siglip2-"},
+    }
+
+    cfg = OmegaConf.create(config)
+    encoder_cfg = next(
+        (
+            item
+            for item in encoder_configs.values()
+            if str(cfg.backbone.name).startswith(item["prefix"])
+        ),
+        None,
+    )
+    if encoder_cfg is None:
+        raise ValueError(f"Unsupported DINO-WM backbone: {cfg.backbone.name}")
+
+    backbone = encoder_cfg.get("model_class", AutoModel).from_pretrained(cfg.backbone.name)
+    if hasattr(backbone, "vision_model"):
+        backbone = backbone.vision_model
+    if "post_init" in encoder_cfg:
+        encoder_cfg["post_init"](backbone)
+
+    embed_dim = encoder_cfg.get("embedding_attr", lambda m: m.config.hidden_size)(backbone)
+    is_cnn = str(cfg.backbone.name).startswith("microsoft/resnet-")
+    num_patches = 1 if is_cnn else (int(cfg.image_size) // int(cfg.patch_size)) ** 2
+    interp_pos_enc = encoder_cfg.get("interpolate_pos_encoding", True)
+
+    embed_dim += sum(int(value) for value in cfg.wm.get("encoding", {}).values())
+    if cfg.backbone.get("is_video_encoder", False):
+        num_patches += num_patches * (int(cfg.n_steps) // 4)
+
+    predictor_kwargs = {k: v for k, v in dict(cfg.predictor).items() if k != "size"}
+    predictor = CausalPredictor(
+        num_patches=num_patches,
+        num_frames=int(cfg.wm.history_size),
+        dim=int(embed_dim),
+        **predictor_kwargs,
+    )
+    extra_encoders = torch.nn.ModuleDict(
+        OrderedDict(
+            (
+                key,
+                Embedder(
+                    in_chans=int(cfg.extra_dims[key]),
+                    emb_dim=int(emb_dim),
+                ),
+            )
+            for key, emb_dim in cfg.wm.get("encoding", {}).items()
+        )
+    )
+
+    return swm.wm.PreJEPA(
+        encoder=spt.backbone.EvalOnly(backbone),
+        predictor=predictor,
+        extra_encoders=extra_encoders,
+        history_size=int(cfg.wm.history_size),
+        num_pred=int(cfg.wm.num_preds),
+        interpolate_pos_encoding=bool(interp_pos_enc),
+    )
+
+
+def build_model(config: dict, weights_path: Path) -> torch.nn.Module:
+    if "_target_" in config:
+        return instantiate(config)
+
+    kind = _infer_train_config_kind(config, weights_path)
+    if kind is not None:
+        print(f"[convert] detected stable-worldmodel training config: {kind}", flush=True)
+        if kind == "dinowm":
+            return _build_dinowm_from_train_config(config)
+        return _build_pldm_or_lewm_from_train_config(config, kind)
+
+    instantiated = instantiate(DictConfig(config))
+    if isinstance(instantiated, torch.nn.Module):
+        return instantiated
+
+    raise ValueError(
+        "Could not build a model from config. Expected either a Hydra config "
+        "with _target_, or a stable-worldmodel PLDM/LeWM training config."
+    )
+
+
+def convert(config_path: Path, weights_path: Path, dst_path: Path) -> None:
+    if not config_path.exists():
+        raise FileNotFoundError(f"Missing config: {config_path}")
+    if not weights_path.exists():
+        raise FileNotFoundError(f"Missing weights: {weights_path}")
+
+    with config_path.open("r") as f:
+        config = json.load(f)
+
+    print(f"[convert] config:  {config_path}", flush=True)
+    print(f"[convert] weights: {weights_path}", flush=True)
+    model = build_model(config, weights_path)
+
+    state_dict = load_state_dict(weights_path)
+    missing, unexpected = model.load_state_dict(state_dict, strict=False)
+    if missing:
+        raise RuntimeError(f"Missing keys while loading weights: {missing[:20]}")
+    if unexpected:
+        raise RuntimeError(f"Unexpected keys while loading weights: {unexpected[:20]}")
+
+    model.eval()
+    model.requires_grad_(False)
+
+    dst_path.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(model, dst_path)
+    print(f"[convert] wrote:   {dst_path}", flush=True)
+    print(f"[convert] class:   {type(model).__module__}.{type(model).__name__}", flush=True)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--src-dir",
+        type=Path,
+        default=default_src_dir(),
+        help="Directory containing HF config.json and weights.pt.",
+    )
+    parser.add_argument(
+        "--config",
+        type=Path,
+        default=None,
+        help="Explicit path to config.json. Defaults to --src-dir/config.json.",
+    )
+    parser.add_argument(
+        "--weights",
+        type=Path,
+        default=None,
+        help="Explicit path to weights.pt. Defaults to --src-dir/weights.pt.",
+    )
+    parser.add_argument(
+        "--dst",
+        type=Path,
+        default=default_dst_path(),
+        help="Destination object checkpoint path.",
+    )
+    return parser.parse_args()
+
+
+def main() -> None:
+    args = parse_args()
+    config_path = args.config or args.src_dir / "config.json"
+    weights_path = args.weights or args.src_dir / "weights.pt"
+    convert(config_path=config_path, weights_path=weights_path, dst_path=args.dst)
+
+
+if __name__ == "__main__":
+    main()
