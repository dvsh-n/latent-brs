+#!/usr/bin/env python3
+"""Convert a shared.models JEPA checkpoint into one using le-wm's own classes.
+
+The training script ``train/lewm_train_mlp.py`` saves the full ``JEPA`` module
+via ``torch.save(model, path)``. Those pickles reference
+``shared.models.VelocityPredictor`` / ``shared.models.JEPA`` etc, so le-wm's
+``eval.py`` (which runs from ``third_party/le-wm`` with only ``module`` and
+``jepa`` on ``sys.path``) cannot unpickle them directly without the whole repo
+on ``sys.path``.
+
+This script loads the source checkpoint with the repo root temporarily on
+``sys.path``, reinstantiates each component using le-wm's own
+``module.py`` / ``jepa.py`` classes, copies the ``state_dict`` over, and
+re-saves a new ``_object.ckpt`` under ``STABLEWM_HOME`` so
+``swm.policy.AutoCostModel`` can load it with no external imports.
+
+Supports both ``ARPredictor`` (legacy) and ``VelocityPredictor`` sources.
+"""
+
+from __future__ import annotations
+
+import argparse
+import os
+import sys
+from pathlib import Path
+
+import torch
+import torch.nn as nn
+
+LEWM_DIR = Path(__file__).resolve().parent
+REPO_ROOT = LEWM_DIR.parent.parent
+
+# Make le-wm's own modules importable as 'module' / 'jepa' (the names that
+# will be baked into the new pickle via __module__).
+if str(LEWM_DIR) not in sys.path:
+    sys.path.insert(0, str(LEWM_DIR))
+
+# Make shared.models importable so we can load the source checkpoint.
+if str(REPO_ROOT) not in sys.path:
+    sys.path.insert(0, str(REPO_ROOT))
+
+
+import module as lewm_module  # noqa: E402  (local le-wm module.py)
+import jepa as lewm_jepa  # noqa: E402  (local le-wm jepa.py)
+
+
+def _introspect_velocity_predictor(src_pred: nn.Module) -> dict:
+    embed_dim = int(src_pred.embed_dim)
+    action_dim = int(getattr(src_pred, "action_dim", embed_dim))
+    linears = [m for m in src_pred.net if isinstance(m, nn.Linear)]
+    hidden_width = int(linears[0].out_features)
+    depth = len(linears) - 1
+    has_dropout = any(isinstance(m, nn.Dropout) for m in src_pred.net)
+    dropout = float(getattr(src_pred, "_dropout", 0.1)) if has_dropout else 0.0
+    return dict(
+        embed_dim=embed_dim,
+        action_dim=action_dim,
+        hidden_width=hidden_width,
+        depth=depth,
+        dropout=dropout,
+    )
+
+
+def _introspect_ar_predictor(src_pred: nn.Module) -> dict:
+    pos = src_pred.pos_embedding
+    num_frames = int(pos.shape[1])
+    input_dim = int(pos.shape[2])
+    transformer = src_pred.transformer
+    depth = len(transformer.layers)
+    first_attn = transformer.layers[0].attn
+    to_qkv = first_attn.to_qkv.weight
+    inner_dim = int(to_qkv.shape[0]) // 3
+    to_out = first_attn.to_out[0] if isinstance(first_attn.to_out, nn.Sequential) else None
+    if to_out is None:
+        raise RuntimeError("Unexpected ARPredictor attention.to_out layout.")
+    hidden_dim = int(to_out.out_features)
+    dim_head = inner_dim // first_attn.heads
+    heads = int(first_attn.heads)
+    mlp_linear = transformer.layers[0].mlp.net[1]
+    mlp_dim = int(mlp_linear.out_features)
+    output_proj = transformer.output_proj
+    if isinstance(output_proj, nn.Linear):
+        output_dim = int(output_proj.out_features)
+    else:
+        output_dim = hidden_dim
+    return dict(
+        num_frames=num_frames,
+        input_dim=input_dim,
+        hidden_dim=hidden_dim,
+        output_dim=output_dim,
+        depth=depth,
+        heads=heads,
+        dim_head=dim_head,
+        mlp_dim=mlp_dim,
+        dropout=0.0,
+        emb_dropout=0.0,
+    )
+
+
+def _introspect_embedder(src_emb: nn.Module) -> dict:
+    input_dim = int(src_emb.patch_embed.in_channels)
+    smoothed_dim = int(src_emb.patch_embed.out_channels)
+    first_linear = src_emb.embed[0]
+    last_linear = src_emb.embed[-1]
+    emb_dim = int(last_linear.out_features)
+    mlp_scale = int(first_linear.out_features // emb_dim)
+    return dict(
+        input_dim=input_dim,
+        smoothed_dim=smoothed_dim,
+        emb_dim=emb_dim,
+        mlp_scale=mlp_scale,
+    )
+
+
+def _rebuild_mlp(src_mlp: nn.Module) -> nn.Module:
+    linears = [m for m in src_mlp.net if isinstance(m, nn.Linear)]
+    input_dim = int(linears[0].in_features)
+    hidden_dim = int(linears[0].out_features)
+    output_dim = int(linears[-1].out_features)
+    norm_module = src_mlp.net[1]
+    if isinstance(norm_module, nn.BatchNorm1d):
+        norm_fn = nn.BatchNorm1d
+    elif isinstance(norm_module, nn.LayerNorm):
+        norm_fn = nn.LayerNorm
+    elif isinstance(norm_module, nn.Identity):
+        norm_fn = None
+    else:
+        norm_fn = type(norm_module)
+    act_module = src_mlp.net[2]
+    act_fn = type(act_module)
+    return lewm_module.MLP(
+        input_dim=input_dim,
+        hidden_dim=hidden_dim,
+        output_dim=output_dim,
+        norm_fn=norm_fn,
+        act_fn=act_fn,
+    )
+
+
+def _rebuild_predictor(src_pred: nn.Module) -> nn.Module:
+    name = type(src_pred).__name__
+    if name == "VelocityPredictor":
+        kwargs = _introspect_velocity_predictor(src_pred)
+        return lewm_module.VelocityPredictor(**kwargs)
+    if name == "ARPredictor":
+        kwargs = _introspect_ar_predictor(src_pred)
+        return lewm_module.ARPredictor(**kwargs)
+    raise RuntimeError(f"Unsupported predictor class: {name}")
+
+
+def _rebuild_embedder(src_emb: nn.Module) -> nn.Module:
+    kwargs = _introspect_embedder(src_emb)
+    return lewm_module.Embedder(**kwargs)
+
+
+def convert(src_path: Path, dst_path: Path) -> None:
+    print(f"[convert] loading source: {src_path}", flush=True)
+    src = torch.load(src_path, map_location="cpu", weights_only=False)
+
+    print(f"[convert] source predictor: {type(src.predictor).__name__}", flush=True)
+
+    new_predictor = _rebuild_predictor(src.predictor)
+    if isinstance(src.action_encoder, nn.Identity):
+        new_action_encoder = nn.Identity()
+    else:
+        new_action_encoder = _rebuild_embedder(src.action_encoder)
+    new_projector = _rebuild_mlp(src.projector)
+    if isinstance(src.pred_proj, nn.Identity):
+        new_pred_proj = None
+    else:
+        new_pred_proj = _rebuild_mlp(src.pred_proj)
+
+    new_model = lewm_jepa.JEPA(
+        encoder=src.encoder,
+        predictor=new_predictor,
+        action_encoder=new_action_encoder,
+        projector=new_projector,
+        pred_proj=new_pred_proj,
+    )
+
+    target_sd = src.state_dict()
+    missing, unexpected = new_model.load_state_dict(target_sd, strict=False)
+    if missing:
+        print(f"[convert] WARNING missing keys: {missing[:10]}{'...' if len(missing) > 10 else ''}", flush=True)
+    if unexpected:
+        print(
+            f"[convert] WARNING unexpected keys: {unexpected[:10]}{'...' if len(unexpected) > 10 else ''}",
+            flush=True,
+        )
+
+    new_model.eval()
+    new_model.requires_grad_(False)
+
+    dst_path.parent.mkdir(parents=True, exist_ok=True)
+    torch.save(new_model, dst_path)
+    print(f"[convert] wrote: {dst_path}", flush=True)
+
+    print(
+        "[convert] new classes:",
+        type(new_model).__module__ + "." + type(new_model).__name__,
+        "|",
+        type(new_predictor).__module__ + "." + type(new_predictor).__name__,
+        flush=True,
+    )
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--src",
+        type=Path,
+        required=True,
+        help="Path to the source *_object.ckpt produced by train/lewm_train_mlp.py (or equivalent).",
+    )
+    parser.add_argument(
+        "--dst",
+        type=Path,
+        default=None,
+        help=(
+            "Destination path for the converted _object.ckpt. "
+            "Defaults to $STABLEWM_HOME/checkpoints/reacher/lewm_vel_object.ckpt."
+        ),
+    )
+    return parser.parse_args()
+
+
+def main() -> None:
+    args = parse_args()
+    src_path = args.src.expanduser().resolve()
+    if not src_path.is_file():
+        raise FileNotFoundError(f"Source checkpoint not found: {src_path}")
+
+    if args.dst is not None:
+        dst_path = args.dst.expanduser().resolve()
+    else:
+        home = os.environ.get("STABLEWM_HOME")
+        if home is None:
+            raise RuntimeError(
+                "No --dst provided and STABLEWM_HOME is unset. "
+                "Either pass --dst or export STABLEWM_HOME=<repo>/lewm_home."
+            )
+        dst_path = Path(home, "checkpoints", "reacher", "lewm_vel_object.ckpt").resolve()
+
+    convert(src_path, dst_path)
+
+
+if __name__ == "__main__":
+    main()
