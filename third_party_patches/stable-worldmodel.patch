@@ -0,0 +1,156 @@
+"""Visualize a trained PushT SAC expert: roll out episodes, save videos, and print metrics."""
+
+import argparse
+import json
+from pathlib import Path
+
+import gymnasium as gym
+import numpy as np
+from loguru import logger
+
+import stable_worldmodel  # noqa: F401 — registers swm/* envs
+from stable_worldmodel.envs.pusht.sb3_wrapper import PushTSACWrapper
+from stable_worldmodel.envs.pusht.expert_policy import SB3Normalizer
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        '--ckpt-path', type=str, default='./models/sac_pusht/expert_policy.zip',
+        help='Path to the SB3 SAC .zip checkpoint.',
+    )
+    parser.add_argument(
+        '--vec-normalize-path', type=str, default='./models/sac_pusht/vec_normalize.pkl',
+        help='Path to the VecNormalize .pkl stats.',
+    )
+    parser.add_argument('--episodes', type=int, default=20)
+    parser.add_argument('--max-steps', type=int, default=200)
+    parser.add_argument('--output-dir', type=Path, default=Path('./runs/viz_pusht_expert'))
+    parser.add_argument('--seed', type=int, default=1000)
+    parser.add_argument('--fps', type=int, default=10)
+    parser.add_argument('--no-video', action='store_true', help='Skip saving MP4 videos.')
+    parser.add_argument('--device', default='cpu', choices=['cpu', 'cuda', 'auto'])
+    return parser.parse_args()
+
+
+def load_sac_policy(ckpt_path: str, vec_normalize_path: str, device: str):
+    import stable_baselines3 as sb3
+
+    if device == 'auto':
+        import torch
+        device = 'cuda' if torch.cuda.is_available() else 'cpu'
+
+    model = sb3.SAC.load(ckpt_path, device=device)
+    normalizer = SB3Normalizer(vec_normalize_path)
+    return model, normalizer
+
+
+def save_video(path: Path, frames: list[np.ndarray], fps: int) -> None:
+    import imageio
+
+    path.parent.mkdir(parents=True, exist_ok=True)
+    writer = imageio.get_writer(str(path), fps=fps, codec='libx264')
+    for frame in frames:
+        writer.append_data(frame)
+    writer.close()
+
+
+def rollout_episode(
+    model,
+    normalizer: SB3Normalizer,
+    episode_idx: int,
+    seed: int,
+    max_steps: int,
+) -> dict:
+    env = gym.make('swm/PushT-v1', max_episode_steps=max_steps, render_mode='rgb_array')
+    sb3_env = PushTSACWrapper(env)
+
+    obs, info = sb3_env.reset(seed=seed + episode_idx)
+    frames = [env.render()]
+
+    total_reward = 0.0
+    success = False
+    steps = 0
+
+    for _ in range(max_steps):
+        normalized_obs = normalizer(obs[None, :]).astype(np.float32)
+        action, _ = model.predict(normalized_obs, deterministic=True)
+        action = action.squeeze()
+
+        obs, reward, terminated, truncated, info = sb3_env.step(action)
+        total_reward += float(reward)
+        steps += 1
+
+        frames.append(env.render())
+
+        if terminated:
+            success = True
+            break
+        if truncated:
+            break
+
+    env.close()
+    return {
+        'episode': episode_idx,
+        'seed': seed + episode_idx,
+        'steps': steps,
+        'total_reward': total_reward,
+        'success': success,
+        'frames': frames,
+    }
+
+
+def main() -> None:
+    args = parse_args()
+    args.output_dir.mkdir(parents=True, exist_ok=True)
+
+    logger.info(f'Loading SAC expert from: {args.ckpt_path}')
+    model, normalizer = load_sac_policy(args.ckpt_path, args.vec_normalize_path, args.device)
+
+    results = []
+    for ep in range(args.episodes):
+        result = rollout_episode(model, normalizer, ep, args.seed, args.max_steps)
+
+        if not args.no_video:
+            video_path = args.output_dir / f'episode_{ep:03d}.mp4'
+            save_video(video_path, result.pop('frames'), args.fps)
+            result['video_path'] = str(video_path)
+        else:
+            result.pop('frames')
+            result['video_path'] = None
+
+        results.append(result)
+        status = 'SUCCESS' if result['success'] else 'FAIL'
+        logger.info(
+            f"[{status}] episode={ep:3d}  steps={result['steps']:3d}  "
+            f"reward={result['total_reward']:.1f}"
+        )
+
+    # Summary
+    successes = sum(r['success'] for r in results)
+    rewards = [r['total_reward'] for r in results]
+    lengths = [r['steps'] for r in results]
+
+    logger.info('--- Summary ---')
+    logger.info(f'Success rate:       {successes}/{args.episodes} ({100 * successes / args.episodes:.1f}%)')
+    logger.info(f'Mean reward:        {np.mean(rewards):.1f} +/- {np.std(rewards):.1f}')
+    logger.info(f'Mean episode length: {np.mean(lengths):.1f} +/- {np.std(lengths):.1f}')
+
+    metrics_path = args.output_dir / 'metrics.json'
+    serializable = [{k: v for k, v in r.items()} for r in results]
+    serializable.append({
+        'summary': {
+            'success_rate': successes / args.episodes,
+            'mean_reward': float(np.mean(rewards)),
+            'std_reward': float(np.std(rewards)),
+            'mean_length': float(np.mean(lengths)),
+            'std_length': float(np.std(lengths)),
+        }
+    })
+    with open(metrics_path, 'w') as f:
+        json.dump(serializable, f, indent=2)
+    logger.info(f'Metrics saved to {metrics_path}')
+
+
+if __name__ == '__main__':
+    main()
