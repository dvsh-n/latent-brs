+"""Diffusion Policy expert for PushT data collection via stable-worldmodel."""
+
+from __future__ import annotations
+
+import copy
+from pathlib import Path
+from typing import Any
+
+import numpy as np
+import torch
+from PIL import Image
+
+from stable_worldmodel.policy import BasePolicy
+
+_ACTION_SCALE = 100.0
+_POLICY_IMAGE_SIZE = 96
+
+
+def _load_bundle(model_dir: str | Path, device: torch.device):
+    from pusht.shared.native_diffusion_policy import (
+        load_native_diffusion_policy_bundle,
+    )
+
+    return load_native_diffusion_policy_bundle(Path(model_dir), device)
+
+
+def _resize_hwc_uint8(image: np.ndarray, size: int) -> np.ndarray:
+    """Resize an (H, W, 3) uint8 image to (size, size, 3)."""
+    if image.shape[0] == size and image.shape[1] == size:
+        return image
+    pil = Image.fromarray(image)
+    pil = pil.resize((size, size), Image.Resampling.BILINEAR)
+    return np.asarray(pil, dtype=np.uint8)
+
+
+class DiffusionExpertPolicy(BasePolicy):
+    """Wraps the native PushT diffusion expert for use with ``World.record_dataset``.
+
+    The diffusion policy produces **absolute** 2D position targets and uses
+    an internal action-chunk queue (``n_action_steps``).  This wrapper
+    translates between the SWM vectorised ``info_dict`` format and the native
+    policy's expected inputs/outputs.
+
+    Args:
+        model_dir: Path to the saved diffusion policy bundle (must contain
+            ``config.json``, ``model.safetensors``, and the pre/post-processor
+            ``.safetensors`` files).
+        device: Torch device string (``"cpu"``, ``"cuda"``, ``"auto"``).
+        noise_std: Optional Gaussian noise added to the *relative* actions
+            for trajectory diversity during collection.
+        seed: RNG seed for action noise.
+    """
+
+    def __init__(
+        self,
+        model_dir: str | Path = 'pusht/models/diffusion_pusht',
+        device: str = 'auto',
+        noise_std: float = 0.0,
+        seed: int | None = None,
+        **kwargs: Any,
+    ):
+        super().__init__(**kwargs)
+        self.type = 'diffusion_expert'
+
+        if device == 'auto':
+            device = 'cuda' if torch.cuda.is_available() else 'cpu'
+        self._device = torch.device(device)
+
+        policy, preprocessor, postprocessor = _load_bundle(model_dir, self._device)
+        self._policy_template = policy
+        self._preprocessor = preprocessor
+        self._postprocessor = postprocessor
+
+        self._policies: list = []
+        self._noise_std = noise_std
+        self._rng = np.random.default_rng(seed)
+        self.seed = seed
+
+    def set_seed(self, seed: int | None) -> None:
+        self.seed = seed
+        self._rng = np.random.default_rng(seed)
+
+    def set_env(self, env: Any) -> None:
+        self.env = env
+        n = getattr(env, 'num_envs', 1)
+        self._policies = []
+        for _ in range(n):
+            p = copy.deepcopy(self._policy_template)
+            p.eval()
+            self._policies.append(p)
+
+    # ------------------------------------------------------------------
+    # Action selection
+    # ------------------------------------------------------------------
+
+    def get_action(self, info_dict: dict, **kwargs: Any) -> np.ndarray:
+        assert hasattr(self, 'env'), 'Call set_env() before get_action()'
+
+        n_envs = len(self._policies)
+        act_shape = self.env.action_space.shape
+        actions_out = np.zeros(act_shape, dtype=np.float32)
+
+        # Extract per-env data from the vectorised info_dict.
+        pixels_all = info_dict['pixels']          # (n, [hist,] H, W, 3)
+        pos_agent_all = info_dict['pos_agent']    # (n, [hist,] 2)
+        step_idx_all = info_dict['step_idx']      # (n, [hist]) or (n,)
+
+        for i in range(n_envs):
+            # Detect episode boundary: step_idx == 0 means the env just reset.
+            si = step_idx_all[i]
+            current_step = int(si[-1]) if np.ndim(si) >= 1 else int(si)
+            if current_step == 0:
+                self._policies[i].reset()
+
+            # --- image: take last history frame, resize to 96x96, CHW float ---
+            pix = pixels_all[i]
+            if pix.ndim == 4:            # (hist, H, W, 3)
+                pix = pix[-1]
+            pix = _resize_hwc_uint8(pix, _POLICY_IMAGE_SIZE)
+            image_t = (
+                torch.from_numpy(pix)
+                .permute(2, 0, 1)
+                .contiguous()
+                .float()
+                .div_(255.0)
+                .unsqueeze(0)            # (1, 3, 96, 96)
+            )
+
+            # --- agent position (2,) ---
+            pa = pos_agent_all[i]
+            if np.ndim(pa) == 2:         # (hist, 2)
+                pa = pa[-1]
+            state_t = torch.from_numpy(np.asarray(pa, dtype=np.float32)).unsqueeze(0)  # (1, 2)
+
+            # --- preprocess & select ---
+            batch = {
+                'observation.image': image_t,
+                'observation.state': state_t,
+            }
+            batch = self._preprocessor(batch)
+            action_t = self._policies[i].select_action(batch)  # (1, 2)
+            action_abs = self._postprocessor(action_t)          # absolute position
+
+            if isinstance(action_abs, torch.Tensor):
+                action_abs = action_abs.detach().cpu().numpy()
+            action_abs = action_abs.reshape(-1)[:2]
+
+            # --- absolute -> relative action for swm/PushT-v1 ---
+            agent_pos = np.asarray(pa, dtype=np.float32)
+            rel_action = np.clip(
+                (action_abs - agent_pos) / _ACTION_SCALE, -1.0, 1.0,
+            ).astype(np.float32)
+
+            if self._noise_std > 0:
+                noise = self._rng.normal(0, self._noise_std, size=rel_action.shape)
+                rel_action = np.clip(rel_action + noise, -1.0, 1.0).astype(np.float32)
+
+            actions_out[i] = rel_action
+
+        return actions_out
