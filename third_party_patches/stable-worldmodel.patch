@@ -0,0 +1,114 @@
+"""Train a goal-conditioned SAC expert policy on PushT."""
+
+import argparse
+from pathlib import Path
+
+import gymnasium as gym
+import torch
+from loguru import logger
+from stable_baselines3 import SAC
+from stable_baselines3.common.callbacks import CheckpointCallback
+from stable_baselines3.common.monitor import Monitor
+from stable_baselines3.common.vec_env import DummyVecEnv, SubprocVecEnv, VecNormalize
+
+import stable_worldmodel  # noqa: F401 — registers swm/* envs
+from stable_worldmodel.envs.pusht.sb3_wrapper import PushTSACWrapper
+
+
+def make_pusht_env(max_episode_steps: int = 200) -> gym.Env:
+    env = gym.make('swm/PushT-v1', max_episode_steps=max_episode_steps)
+    env = PushTSACWrapper(env)
+    return Monitor(env)
+
+
+def train(args: argparse.Namespace) -> None:
+    device = 'cuda' if torch.cuda.is_available() else 'cpu'
+    save_dir = Path(args.save_dir)
+    save_dir.mkdir(parents=True, exist_ok=True)
+
+    logger.info(f'Training PushT SAC expert | Steps: {args.total_timesteps}')
+    logger.info(f'Device: {device} | Save dir: {save_dir} | Workers: {args.num_workers}')
+
+    env_fns = [
+        lambda: make_pusht_env(args.max_episode_steps)
+        for _ in range(args.num_workers)
+    ]
+    if args.num_workers > 1:
+        vec_env = SubprocVecEnv(env_fns)
+    else:
+        vec_env = DummyVecEnv(env_fns)
+    vec_env = VecNormalize(
+        vec_env, norm_obs=True, norm_reward=True, clip_obs=10.0,
+    )
+
+    model = SAC(
+        policy='MlpPolicy',
+        env=vec_env,
+        verbose=1,
+        learning_rate=3e-4,
+        buffer_size=1_000_000,
+        batch_size=args.batch_size,
+        learning_starts=args.learning_starts,
+        ent_coef='auto',
+        policy_kwargs={'net_arch': [512, 512, 512, 512]},
+        device=device,
+        seed=args.seed,
+    )
+
+    checkpoint_callback = CheckpointCallback(
+        save_freq=args.checkpoint_freq,
+        save_path=str(save_dir),
+        name_prefix='sac_pusht',
+    )
+
+    try:
+        model.learn(
+            total_timesteps=args.total_timesteps,
+            callback=checkpoint_callback,
+            progress_bar=True,
+            log_interval=30,
+        )
+        model.save(save_dir / 'expert_policy')
+        vec_env.save(str(save_dir / 'vec_normalize.pkl'))
+        logger.success(f'Training complete. Saved to {save_dir}')
+    except Exception as e:
+        logger.error(f'Training failed: {e}')
+        raise
+    finally:
+        vec_env.close()
+        if torch.cuda.is_available():
+            torch.cuda.empty_cache()
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        '--save-dir', type=str, default='./models/sac_pusht',
+        help='Directory to save the trained policy and normalization stats.',
+    )
+    parser.add_argument(
+        '--total-timesteps', type=int, default=5_000_000,
+        help='Total environment steps for training.',
+    )
+    parser.add_argument(
+        '--max-episode-steps', type=int, default=200,
+        help='Max steps per episode in the training env.',
+    )
+    parser.add_argument('--batch-size', type=int, default=4096)
+    parser.add_argument('--learning-starts', type=int, default=10_000)
+    parser.add_argument(
+        '--checkpoint-freq', type=int, default=100_000,
+        help='Save a checkpoint every N environment steps.',
+    )
+    parser.add_argument(
+        '--num-workers', type=int, default=16,
+        help='Number of parallel env workers for data collection.',
+    )
+    parser.add_argument('--seed', type=int, default=0)
+    args = parser.parse_args()
+
+    train(args)
+
+
+if __name__ == '__main__':
+    main()
