diff --git a/stable_worldmodel/envs/pusht/expert_policy.py b/stable_worldmodel/envs/pusht/expert_policy.py
index ecf1622..01290d1 100644
--- a/stable_worldmodel/envs/pusht/expert_policy.py
+++ b/stable_worldmodel/envs/pusht/expert_policy.py
@@ -1,8 +1,112 @@
+import pickle
+
 import numpy as np
 
 from stable_worldmodel.policy import BasePolicy
 
 
+class SB3Normalizer:
+    """Normalizer using Stable Baselines3 VecNormalize statistics."""
+
+    def __init__(
+        self,
+        stats_path: str,
+        clip_obs: float = 10.0,
+        epsilon: float = 1e-8,
+    ):
+        with open(stats_path, 'rb') as f:
+            vec_normalize = pickle.load(f)
+
+        self.mean = vec_normalize.obs_rms.mean
+        self.var = vec_normalize.obs_rms.var
+        self.epsilon = epsilon
+        self.clip_obs = clip_obs
+
+    def __call__(self, obs: np.ndarray) -> np.ndarray:
+        norm_obs = (obs - self.mean) / np.sqrt(self.var + self.epsilon)
+        return np.clip(norm_obs, -self.clip_obs, self.clip_obs)
+
+
+class PushTExpertPolicy(BasePolicy):
+    """Goal-conditioned SAC expert policy for PushT.
+
+    Loads a Stable Baselines3 SAC checkpoint trained on the 14D
+    observation (7D state + 7D goal_state) produced by
+    ``stable_worldmodel.envs.pusht.sb3_wrapper.PushTSACWrapper``.
+    """
+
+    def __init__(
+        self,
+        ckpt_path: str,
+        vec_normalize_path: str,
+        noise_std: float = 0.0,
+        seed: int | None = None,
+        device: str = 'cpu',
+        **kwargs,
+    ):
+        """
+        Args:
+            ckpt_path: Path to the SB3 ``.zip`` policy checkpoint.
+            vec_normalize_path: Path to the ``.pkl`` VecNormalize stats.
+            noise_std: Std-dev of Gaussian noise added to actions for diversity.
+            seed: Random seed for action noise.
+            device: Device to load the model on.
+        """
+        super().__init__(**kwargs)
+
+        try:
+            import stable_baselines3 as sb3
+        except ImportError:
+            raise ImportError(
+                'stable_baselines3 is required to use PushTExpertPolicy. '
+                "Install it via 'pip install stable-baselines3'."
+            )
+
+        self.model = sb3.SAC.load(ckpt_path, device=device)
+        self.normalizer = SB3Normalizer(vec_normalize_path)
+        self.rng = np.random.default_rng(seed)
+        self.noise_std = noise_std
+        self.type = 'expert'
+
+        if seed is not None:
+            self.model.set_random_seed(seed)
+
+    def set_seed(self, seed: int | None) -> None:
+        self.seed = seed
+        self.rng = np.random.default_rng(seed)
+
+    def set_env(self, env):
+        self.env = env
+
+    def get_action(self, info_dict, **kwargs):
+        assert hasattr(self, 'env'), 'Environment not set for the policy'
+
+        # state: (num_envs, history, 7) — take the latest frame
+        state = info_dict['state']
+        if state.ndim == 3:
+            state = state[:, -1, :]
+        state = state.squeeze()
+        if state.ndim == 1:
+            state = state[None, :]
+
+        # goal_state: (num_envs, history, 7) or (num_envs, 7)
+        goal_state = info_dict['goal_state']
+        if goal_state.ndim == 3:
+            goal_state = goal_state[:, -1, :]
+        goal_state = goal_state.squeeze()
+        if goal_state.ndim == 1:
+            goal_state = goal_state[None, :]
+
+        obs = np.concatenate([state, goal_state], axis=-1).astype(np.float32)
+        normalized_obs = self.normalizer(obs)
+
+        actions, _ = self.model.predict(normalized_obs, deterministic=False)
+        if self.noise_std > 0:
+            noise = self.rng.normal(0, self.noise_std, size=actions.shape)
+            actions = actions + noise
+        return np.clip(actions, -1.0, 1.0).astype(np.float32)
+
+
 class WeakPolicy(BasePolicy):
     """Collection policy for PushT environment."""
 
