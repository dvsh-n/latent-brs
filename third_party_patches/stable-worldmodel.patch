@@ -0,0 +1,33 @@
+"""Gymnasium wrapper that flattens PushT for Stable Baselines3 compatibility."""
+
+import gymnasium as gym
+import numpy as np
+from gymnasium import spaces
+
+
+class PushTSACWrapper(gym.Wrapper):
+    """Flattens the PushT dict observation into a goal-conditioned vector.
+
+    SB3 requires a flat Box observation space. This wrapper concatenates
+    the 7D state (agent_xy, block_xy, block_angle, agent_vel) with the
+    7D goal_state to produce a 14D observation.
+    """
+
+    def __init__(self, env: gym.Env):
+        super().__init__(env)
+        self.observation_space = spaces.Box(
+            low=-np.inf, high=np.inf, shape=(14,), dtype=np.float32,
+        )
+
+    def _flatten_obs(self, obs: dict, info: dict) -> np.ndarray:
+        return np.concatenate(
+            [obs['state'], info['goal_state']]
+        ).astype(np.float32)
+
+    def reset(self, **kwargs):
+        obs, info = self.env.reset(**kwargs)
+        return self._flatten_obs(obs, info), info
+
+    def step(self, action):
+        obs, reward, terminated, truncated, info = self.env.step(action)
+        return self._flatten_obs(obs, info), reward, terminated, truncated, info
