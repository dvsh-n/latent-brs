new file mode 100644
index 0000000..7f276eb
--- /dev/null
+++ b/scripts/expert/viz_diffusion_pusht_expert.py
@@ -0,0 +1,203 @@
+"""Visualize a trained PushT diffusion expert: roll out episodes, save videos, and print metrics."""
+
+import argparse
+import json
+from pathlib import Path
+
+import gymnasium as gym
+import numpy as np
+import torch
+from loguru import logger
+from PIL import Image
+
+import stable_worldmodel
+
+_ACTION_SCALE = 100.0
+_POLICY_IMAGE_SIZE = 96
+
+# Fixed goal matching the lerobot/pusht training data:
+# block at center (256, 256) with angle pi/4.
+# Format: [agent_x, agent_y, block_x, block_y, block_angle, vel_x, vel_y]
+_FIXED_GOAL_STATE = np.array([256.0, 400.0, 256.0, 256.0, np.pi / 4, 0.0, 0.0])
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        '--model-dir', type=str, default='pusht/models/pusht_diffusion_expert',
+        help='Path to the saved diffusion policy bundle directory.',
+    )
+    parser.add_argument('--episodes', type=int, default=20)
+    parser.add_argument('--max-steps', type=int, default=200)
+    parser.add_argument('--output-dir', type=Path, default=Path('./runs/viz_diffusion_pusht_expert'))
+    parser.add_argument('--seed', type=int, default=1000)
+    parser.add_argument('--fps', type=int, default=10)
+    parser.add_argument('--no-video', action='store_true', help='Skip saving MP4 videos.')
+    parser.add_argument('--device', default='auto', choices=['cpu', 'cuda', 'auto'])
+    return parser.parse_args()
+
+
+def resolve_device(device: str) -> torch.device:
+    if device != 'auto':
+        return torch.device(device)
+    if torch.cuda.is_available():
+        return torch.device('cuda')
+    return torch.device('cpu')
+
+
+def load_bundle(model_dir: str, device: torch.device):
+    from pusht.shared.native_diffusion_policy import (
+        load_native_diffusion_policy_bundle,
+    )
+
+    return load_native_diffusion_policy_bundle(Path(model_dir), device)
+
+
+def save_video(path: Path, frames: list[np.ndarray], fps: int) -> None:
+    import imageio
+
+    path.parent.mkdir(parents=True, exist_ok=True)
+    writer = imageio.get_writer(str(path), fps=fps, codec='libx264')
+    for frame in frames:
+        writer.append_data(frame)
+    writer.close()
+
+
+def _resize_hwc(image: np.ndarray, size: int) -> np.ndarray:
+    if image.shape[0] == size and image.shape[1] == size:
+        return image
+    pil = Image.fromarray(image)
+    pil = pil.resize((size, size), Image.Resampling.BILINEAR)
+    return np.asarray(pil, dtype=np.uint8)
+
+
+def rollout_episode(
+    policy,
+    preprocessor,
+    postprocessor,
+    device: torch.device,
+    episode_idx: int,
+    seed: int,
+    max_steps: int,
+) -> dict:
+    env = gym.make('swm/PushT-v1', max_episode_steps=max_steps, render_mode='rgb_array')
+    obs, info = env.reset(seed=seed + episode_idx, options={'goal_state': _FIXED_GOAL_STATE})
+    policy.reset()
+
+    frames = [env.render()]
+    total_reward = 0.0
+    success = False
+    steps = 0
+
+    for _ in range(max_steps):
+        # Build the observation batch for the diffusion policy.
+        pixels = env.render()
+        pixels = _resize_hwc(pixels, _POLICY_IMAGE_SIZE)
+        image_t = (
+            torch.from_numpy(pixels)
+            .permute(2, 0, 1)
+            .contiguous()
+            .float()
+            .div_(255.0)
+            .unsqueeze(0)
+        )
+
+        agent_pos = np.asarray(info['pos_agent'], dtype=np.float32)
+        state_t = torch.from_numpy(agent_pos).unsqueeze(0)
+
+        batch = {
+            'observation.image': image_t,
+            'observation.state': state_t,
+        }
+        batch = preprocessor(batch)
+
+        with torch.no_grad():
+            action_t = policy.select_action(batch)
+        action_abs = postprocessor(action_t)
+        if isinstance(action_abs, torch.Tensor):
+            action_abs = action_abs.detach().cpu().numpy()
+        action_abs = action_abs.reshape(-1)[:2]
+
+        rel_action = np.clip(
+            (action_abs - agent_pos) / _ACTION_SCALE, -1.0, 1.0,
+        ).astype(np.float32)
+
+        obs, reward, terminated, truncated, info = env.step(rel_action)
+        total_reward += float(reward)
+        steps += 1
+        frames.append(env.render())
+
+        if terminated:
+            success = True
+            break
+        if truncated:
+            break
+
+    env.close()
+    return {
+        'episode': episode_idx,
+        'seed': seed + episode_idx,
+        'steps': steps,
+        'total_reward': total_reward,
+        'success': success,
+        'frames': frames,
+    }
+
+
+def main() -> None:
+    args = parse_args()
+    args.output_dir.mkdir(parents=True, exist_ok=True)
+    device = resolve_device(args.device)
+
+    logger.info(f'Loading diffusion expert from: {args.model_dir}')
+    policy, preprocessor, postprocessor = load_bundle(args.model_dir, device)
+
+    results = []
+    for ep in range(args.episodes):
+        result = rollout_episode(
+            policy, preprocessor, postprocessor, device,
+            ep, args.seed, args.max_steps,
+        )
+
+        if not args.no_video:
+            video_path = args.output_dir / f'episode_{ep:03d}.mp4'
+            save_video(video_path, result.pop('frames'), args.fps)
+            result['video_path'] = str(video_path)
+        else:
+            result.pop('frames')
+            result['video_path'] = None
+
+        results.append(result)
+        status = 'SUCCESS' if result['success'] else 'FAIL'
+        logger.info(
+            f"[{status}] episode={ep:3d}  steps={result['steps']:3d}  "
+            f"reward={result['total_reward']:.1f}"
+        )
+
+    successes = sum(r['success'] for r in results)
+    rewards = [r['total_reward'] for r in results]
+    lengths = [r['steps'] for r in results]
+
+    logger.info('--- Summary ---')
+    logger.info(f'Success rate:        {successes}/{args.episodes} ({100 * successes / args.episodes:.1f}%)')
+    logger.info(f'Mean reward:         {np.mean(rewards):.1f} +/- {np.std(rewards):.1f}')
+    logger.info(f'Mean episode length: {np.mean(lengths):.1f} +/- {np.std(lengths):.1f}')
+
+    metrics_path = args.output_dir / 'metrics.json'
+    serializable = list(results)
+    serializable.append({
+        'summary': {
+            'success_rate': successes / args.episodes,
+            'mean_reward': float(np.mean(rewards)),
+            'std_reward': float(np.std(rewards)),
+            'mean_length': float(np.mean(lengths)),
+            'std_length': float(np.std(lengths)),
+        }
+    })
+    with open(metrics_path, 'w') as f:
+        json.dump(serializable, f, indent=2)
+    logger.info(f'Metrics saved to {metrics_path}')
+
+
+if __name__ == '__main__':
+    main()
